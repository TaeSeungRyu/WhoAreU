{
  "name": "who-are-u",
  "productName": "WhoAreU",
  "version": "0.1.0",
  "description": "내 PC에서 실행 중인 프로그램의 출처·설치일·용량을 확인하는 트레이 앱",
  "author": {
    "name": "WhoAreU"
  },
  "license": "UNLICENSED",
  "main": "main.js",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/make-icon.js",
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.whoareu.app",
    "productName": "WhoAreU",
    "copyright": "Copyright © 2026 WhoAreU",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "src/system/*.ps1"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "publisherName": "WhoAreU",
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "WhoAreU-${version}-portable.exe"
    }
  }
}
